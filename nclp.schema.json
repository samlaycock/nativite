{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/nclp.schema.json",
  "title": "Native Chrome Layout Protocol (NCLP) v1",
  "description": "JSON Schema for the Native Chrome Layout Protocol (NCLP) v1.",
  "oneOf": [
    { "$ref": "#/$defs/snapshotEnvelope" },
    { "$ref": "#/$defs/patchEnvelope" },
    { "$ref": "#/$defs/eventEnvelope" }
  ],

  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1
    },

    "version": {
      "type": "integer",
      "const": 1
    },

    "jsonValue": {
      "description": "Any JSON-compatible value.",
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      ]
    },

    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },

    "booleanMap": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },

    "jsonMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/jsonValue" }
    },

    "badgeMap": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [{ "type": "string" }, { "type": "number" }]
      }
    },

    "children": {
      "type": "array",
      "items": { "$ref": "#/$defs/identifier" },
      "uniqueItems": true
    },

    "coreContainerKind": {
      "type": "string",
      "enum": [
        "menubar",
        "window",
        "titlebar",
        "toolbar",
        "menu",
        "section",
        "group",
        "tabs",
        "sidebar",
        "stack",
        "split"
      ]
    },

    "coreLeafKind": {
      "type": "string",
      "enum": [
        "tab",
        "action",
        "item",
        "title",
        "search",
        "separator",
        "spacer"
      ]
    },

    "role": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "destructive",
        "navigation",
        "confirm",
        "cancel"
      ]
    },

    "placement": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "top",
        "bottom",
        "leading",
        "trailing",
        "sidebar",
        "overflow"
      ]
    },

    "presentation": {
      "type": "string",
      "enum": ["default", "compact", "prominent", "subtle"]
    },

    "extensionMap": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "$ref": "#/$defs/jsonValue" }
      }
    },

    "baseNodeFields": {
      "type": "object",
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "label": { "type": "string" },
        "icon": { "type": "string" },
        "role": { "$ref": "#/$defs/role" },
        "placement": { "$ref": "#/$defs/placement" },
        "presentation": { "$ref": "#/$defs/presentation" },
        "description": { "type": "string" },
        "tooltip": { "type": "string" },
        "accessibilityLabel": { "type": "string" },
        "meta": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        },
        "ext": { "$ref": "#/$defs/extensionMap" }
      },
      "required": ["id"],
      "additionalProperties": false
    },

    "containerNode": {
      "allOf": [
        { "$ref": "#/$defs/baseNodeFields" },
        {
          "type": "object",
          "properties": {
            "kind": { "$ref": "#/$defs/coreContainerKind" },
            "children": { "$ref": "#/$defs/children" }
          },
          "required": ["kind", "children"]
        }
      ]
    },

    "leafNode": {
      "allOf": [
        { "$ref": "#/$defs/baseNodeFields" },
        {
          "type": "object",
          "properties": {
            "kind": { "$ref": "#/$defs/coreLeafKind" }
          },
          "required": ["kind"],
          "not": {
            "required": ["children"]
          }
        }
      ]
    },

    "node": {
      "oneOf": [
        { "$ref": "#/$defs/containerNode" },
        { "$ref": "#/$defs/leafNode" }
      ]
    },

    "nodesMap": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": { "$ref": "#/$defs/node" }
    },

    "state": {
      "type": "object",
      "properties": {
        "selected": { "$ref": "#/$defs/stringMap" },
        "disabled": { "$ref": "#/$defs/booleanMap" },
        "hidden": { "$ref": "#/$defs/booleanMap" },
        "badges": { "$ref": "#/$defs/badgeMap" },
        "values": { "$ref": "#/$defs/jsonMap" }
      },
      "required": ["selected", "disabled", "hidden", "badges"],
      "additionalProperties": {
        "$ref": "#/$defs/jsonMap"
      }
    },

    "snapshotEnvelope": {
      "type": "object",
      "properties": {
        "type": { "const": "snapshot" },
        "version": { "$ref": "#/$defs/version" },
        "docId": { "$ref": "#/$defs/identifier" },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "root": { "$ref": "#/$defs/identifier" },
        "nodes": { "$ref": "#/$defs/nodesMap" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": [
        "type",
        "version",
        "docId",
        "revision",
        "root",
        "nodes",
        "state"
      ],
      "additionalProperties": false
    },

    "putNodeOp": {
      "type": "object",
      "properties": {
        "op": { "const": "put-node" },
        "node": { "$ref": "#/$defs/node" }
      },
      "required": ["op", "node"],
      "additionalProperties": false
    },

    "removeNodeOp": {
      "type": "object",
      "properties": {
        "op": { "const": "remove-node" },
        "id": { "$ref": "#/$defs/identifier" }
      },
      "required": ["op", "id"],
      "additionalProperties": false
    },

    "setChildrenOp": {
      "type": "object",
      "properties": {
        "op": { "const": "set-children" },
        "id": { "$ref": "#/$defs/identifier" },
        "children": { "$ref": "#/$defs/children" }
      },
      "required": ["op", "id", "children"],
      "additionalProperties": false
    },

    "setPropsOp": {
      "type": "object",
      "properties": {
        "op": { "const": "set-props" },
        "id": { "$ref": "#/$defs/identifier" },
        "props": {
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "icon": { "type": "string" },
            "role": { "$ref": "#/$defs/role" },
            "placement": { "$ref": "#/$defs/placement" },
            "presentation": { "$ref": "#/$defs/presentation" },
            "description": { "type": "string" },
            "tooltip": { "type": "string" },
            "accessibilityLabel": { "type": "string" },
            "meta": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/jsonValue" }
            },
            "ext": { "$ref": "#/$defs/extensionMap" }
          },
          "minProperties": 1,
          "additionalProperties": false
        }
      },
      "required": ["op", "id", "props"],
      "additionalProperties": false
    },

    "setStateOp": {
      "type": "object",
      "properties": {
        "op": { "const": "set-state" },
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "key": { "$ref": "#/$defs/identifier" },
        "value": { "$ref": "#/$defs/jsonValue" }
      },
      "required": ["op", "bucket", "key", "value"],
      "additionalProperties": false
    },

    "removeStateOp": {
      "type": "object",
      "properties": {
        "op": { "const": "remove-state" },
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "key": { "$ref": "#/$defs/identifier" }
      },
      "required": ["op", "bucket", "key"],
      "additionalProperties": false
    },

    "patchOp": {
      "oneOf": [
        { "$ref": "#/$defs/putNodeOp" },
        { "$ref": "#/$defs/removeNodeOp" },
        { "$ref": "#/$defs/setChildrenOp" },
        { "$ref": "#/$defs/setPropsOp" },
        { "$ref": "#/$defs/setStateOp" },
        { "$ref": "#/$defs/removeStateOp" }
      ]
    },

    "patchEnvelope": {
      "type": "object",
      "properties": {
        "type": { "const": "patch" },
        "version": { "$ref": "#/$defs/version" },
        "docId": { "$ref": "#/$defs/identifier" },
        "baseRevision": {
          "type": "integer",
          "minimum": 1
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "ops": {
          "type": "array",
          "items": { "$ref": "#/$defs/patchOp" },
          "minItems": 1
        }
      },
      "required": [
        "type",
        "version",
        "docId",
        "baseRevision",
        "revision",
        "ops"
      ],
      "additionalProperties": false
    },

    "eventName": {
      "type": "string",
      "enum": ["activate", "select", "open", "close", "input", "submit"]
    },

    "eventPayload": {
      "type": "object",
      "properties": {
        "name": { "$ref": "#/$defs/eventName" },
        "target": { "$ref": "#/$defs/identifier" },
        "value": { "$ref": "#/$defs/jsonValue" },
        "meta": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      },
      "required": ["name", "target"],
      "additionalProperties": false
    },

    "eventEnvelope": {
      "type": "object",
      "properties": {
        "type": { "const": "event" },
        "version": { "$ref": "#/$defs/version" },
        "docId": { "$ref": "#/$defs/identifier" },
        "event": { "$ref": "#/$defs/eventPayload" }
      },
      "required": ["type", "version", "docId", "event"],
      "additionalProperties": false
    }
  }
}
