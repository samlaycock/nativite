{
  "name": "nativite",
  "version": "0.2.0",
  "description": "Build native iOS, macOS, and Android shells around Vite apps.",
  "keywords": [
    "android",
    "bun",
    "ios",
    "kotlin",
    "macos",
    "native",
    "swift",
    "vite",
    "webview"
  ],
  "homepage": "https://github.com/samlaycock/nativite#readme",
  "bugs": {
    "url": "https://github.com/samlaycock/nativite/issues"
  },
  "license": "MIT",
  "author": "Samuel Laycock",
  "repository": {
    "type": "git",
    "url": "https://github.com/samlaycock/nativite"
  },
  "bin": {
    "nativite": "./dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.mjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.mjs"
    },
    "./chrome": {
      "types": "./dist/chrome/public.d.ts",
      "import": "./dist/chrome/public.mjs"
    },
    "./css": {
      "types": "./dist/css-vars/index.d.ts",
      "import": "./dist/css-vars/index.mjs"
    },
    "./background": {
      "types": "./dist/background.d.ts",
      "import": "./dist/background.mjs"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "import": "./dist/test/index.mjs"
    },
    "./vitest-browser-provider": {
      "types": "./dist/vitest-browser-provider/index.d.ts",
      "import": "./dist/vitest-browser-provider/index.mjs"
    },
    "./plugins/contacts": {
      "types": "./dist/plugins/contacts/index.d.ts",
      "import": "./dist/plugins/contacts/index.mjs"
    },
    "./plugins/calendar": {
      "types": "./dist/plugins/calendar/index.d.ts",
      "import": "./dist/plugins/calendar/index.mjs"
    },
    "./plugins/notifications": {
      "types": "./dist/plugins/notifications/index.d.ts",
      "import": "./dist/plugins/notifications/index.mjs"
    },
    "./plugins/secure-store": {
      "types": "./dist/plugins/secure-store/index.d.ts",
      "import": "./dist/plugins/secure-store/index.mjs"
    },
    "./plugins/local-auth": {
      "types": "./dist/plugins/local-auth/index.d.ts",
      "import": "./dist/plugins/local-auth/index.mjs"
    },
    "./plugins/system-controls": {
      "types": "./dist/plugins/system-controls/index.d.ts",
      "import": "./dist/plugins/system-controls/index.mjs"
    },
    "./plugins/haptics": {
      "types": "./dist/plugins/haptics/index.d.ts",
      "import": "./dist/plugins/haptics/index.mjs"
    },
    "./plugins/app-integrity": {
      "types": "./dist/plugins/app-integrity/index.d.ts",
      "import": "./dist/plugins/app-integrity/index.mjs"
    },
    "./plugins/capture-protection": {
      "types": "./dist/plugins/capture-protection/index.d.ts",
      "import": "./dist/plugins/capture-protection/index.mjs"
    },
    "./globals": {
      "types": "./dist/globals.d.ts"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "test": "bun test",
    "test:native": "bun run test:native:ios && bun run test:native:android",
    "test:native:ios": "bun run scripts/test-native-ios.ts",
    "test:native:android": "bun run scripts/test-native-android.ts",
    "test:generated:native": "bun run scripts/test-generated-native-apps.ts",
    "test:generated:native:ios": "bun run scripts/test-generated-native-apps.ts --platform=ios",
    "test:generated:native:macos": "bun run scripts/test-generated-native-apps.ts --platform=macos",
    "test:generated:native:android": "bun run scripts/test-generated-native-apps.ts --platform=android",
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --type-aware --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "ci:publish": "bun run build && bun run typecheck && bun run lint && bun run fmt:check && bun run test && changeset publish"
  },
  "dependencies": {
    "commander": "14.0.3",
    "picocolors": "1.1.1",
    "sharp": "0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@types/bun": "latest",
    "@types/node": "25.3.0",
    "oxfmt": "0.33.0",
    "oxlint": "1.48.0",
    "oxlint-tsgolint": "0.14.0",
    "tsdown": "0.20.3",
    "typescript": "^5",
    "vite": "7.3.1"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.9"
}
